# Cluster configuration
cluster_name           = "talos"
control_plane_count    = 1
worker_count           = 1
server_type_controlplane = "cx22"
server_type_worker       = "cx22"
location               = "nbg1"
talos_version          = "v1.11"

# Packer snapshot ID (from `make build-image` output)
image_id = "123456789"

# Network (defaults are usually fine)
# network_cidr = "10.0.0.0/16"
# subnet_cidr  = "10.0.1.0/24"
